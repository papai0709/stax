# STAX - Sample Environment Configuration
# Copy this file to .env and fill in your values
# Then run: docker run -d -p 5001:5001 --env-file .env papai0709/stax:latest

# ============================================================
# PLATFORM CONFIGURATION (Required)
# ============================================================
# Choose one: ADO (Azure DevOps) or JIRA
PLATFORM_TYPE=ADO

# ============================================================
# AZURE DEVOPS CONFIGURATION (Required if PLATFORM_TYPE=ADO)
# ============================================================
ADO_ORGANIZATION=your-organization
ADO_PROJECT=your-project
ADO_PAT=your-personal-access-token

# ============================================================
# JIRA CONFIGURATION (Required if PLATFORM_TYPE=JIRA)
# ============================================================
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_USERNAME=your.email@company.com
# JIRA_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=PROJ

# ============================================================
# AI SERVICE CONFIGURATION (Required)
# ============================================================
# Choose one: OPENAI, AZURE_OPENAI, or GITHUB
AI_SERVICE_PROVIDER=AZURE_OPENAI

# --- OpenAI Configuration (if AI_SERVICE_PROVIDER=OPENAI) ---
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4

# --- Azure OpenAI Configuration (if AI_SERVICE_PROVIDER=AZURE_OPENAI) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- GitHub Models Configuration (if AI_SERVICE_PROVIDER=GITHUB) ---
# Free with any GitHub account!
# Get token from: https://github.com/settings/tokens
# GITHUB_TOKEN=github_pat_your-token
# GITHUB_MODEL=gpt-4o-mini

# ============================================================
# OPTIONAL: Work Item Type Configuration
# ============================================================
# REQUIREMENT_TYPE=Epic
# USER_STORY_TYPE=User Story
# TEST_CASE_EXTRACTION_TYPE=Test Case
# AUTO_TEST_CASE_EXTRACTION=false
